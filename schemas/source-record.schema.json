{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kingpo.example/schemas/source-record.schema.json",
  "title": "Source Record",
  "type": "object",
  "required": ["source_id", "source_type", "source_tier", "title", "language", "review_status", "retrieved_at"],
  "properties": {
    "source_id": { "type": "string", "pattern": "^SRC-[A-Z0-9-]+$" },
    "source_type": { "enum": ["user_confirmed", "owned_website", "owned_document", "official_standard_body", "public_reference", "competitor_reference", "legacy_site"] },
    "source_tier": { "enum": ["T1", "T2", "T3", "T4", "T5"] },
    "title": { "type": "string", "minLength": 1 },
    "url_or_file": { "type": "string" },
    "file_hash": { "type": "string" },
    "source_owner": { "type": "string" },
    "language": { "type": "string" },
    "document_version": { "type": "string" },
    "retrieved_at": { "type": "string", "format": "date" },
    "valid_from": { "type": "string", "format": "date" },
    "valid_until": { "type": "string", "format": "date" },
    "legacy_status": { "enum": ["current", "legacy", "unknown", "not_applicable"] },
    "public_permission": { "enum": ["approved", "restricted", "internal_only", "unknown"] },
    "review_status": { "enum": ["unreviewed", "reviewed", "conflict_detected", "rejected"] },
    "reviewer": { "type": "string" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
