{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kingpo.example/schemas/release-gate.schema.json",
  "title": "Release Gate",
  "type": "object",
  "required": ["release_id", "entity_ids", "checks", "blockers", "decision", "reviewer"],
  "properties": {
    "release_id": { "type": "string", "pattern": "^REL-[A-Z0-9-]+$" },
    "entity_ids": { "type": "array", "items": { "type": "string" } },
    "checks": {
      "type": "object",
      "required": [
        "sources_complete",
        "high_risk_claims_reviewed",
        "standard_mappings_reviewed",
        "assets_public_approved",
        "canonical_resolved",
        "duplicate_slug_checked",
        "no_competitor_asset_public",
        "no_fake_price_rating_availability"
      ],
      "properties": {
        "sources_complete": { "type": "boolean" },
        "high_risk_claims_reviewed": { "type": "boolean" },
        "standard_mappings_reviewed": { "type": "boolean" },
        "assets_public_approved": { "type": "boolean" },
        "canonical_resolved": { "type": "boolean" },
        "duplicate_slug_checked": { "type": "boolean" },
        "no_competitor_asset_public": { "type": "boolean" },
        "no_fake_price_rating_availability": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "blockers": { "type": "array", "items": { "$ref": "common-definitions.schema.json#/$defs/blockerCode" }, "uniqueItems": true },
    "decision": { "enum": ["approved_for_staging", "approved_for_publish", "blocked"] },
    "reviewer": { "type": "string" },
    "reviewer_role": { "$ref": "common-definitions.schema.json#/$defs/reviewRole" },
    "approval_timestamp": { "type": "string", "format": "date-time" },
    "notes": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "blockers": { "minItems": 1 } } },
      "then": { "properties": { "decision": { "const": "blocked" } } }
    },
    {
      "if": { "properties": { "decision": { "const": "approved_for_publish" } } },
      "then": {
        "required": ["reviewer_role", "approval_timestamp"],
        "properties": {
          "reviewer_role": { "enum": ["publisher", "administrator"] },
          "blockers": { "maxItems": 0 },
          "checks": {
            "properties": {
              "sources_complete": { "const": true },
              "high_risk_claims_reviewed": { "const": true },
              "standard_mappings_reviewed": { "const": true },
              "assets_public_approved": { "const": true },
              "canonical_resolved": { "const": true },
              "duplicate_slug_checked": { "const": true },
              "no_competitor_asset_public": { "const": true },
              "no_fake_price_rating_availability": { "const": true }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
